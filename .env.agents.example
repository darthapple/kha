# Copy this file to .env.agents and fill in the values.
# .env.agents is gitignored — never commit real secrets.

# ── ClickUp ───────────────────────────────────────────────────────────────────
# Personal API token: ClickUp → Settings → Apps → API Token
CLICKUP_API_KEY=pk_...

# The List ID where your tasks live.
# How to find it: right-click the list in the sidebar → "Copy link"
#   URL pattern: app.clickup.com/{workspace}/v/l/{LIST_ID}
# Only the List is needed — kha doesn't use Space or Folder IDs.
CLICKUP_LIST_ID=

# ── Project repo ──────────────────────────────────────────────────────────────
# The repo the skill containers will clone and work on.
PROJECT_REPO_URL=https://github.com/your-org/your-repo.git

# ── Git auth (required for develop and qa skills) ─────────────────────────────
# GitHub personal access token with repo scope.
GIT_TOKEN=ghp_...

# ── Claude auth — choose ONE, leave the other commented out ───────────────────

# Option A — Claude Code subscription (recommended)
# Run `claude setup-token` once and paste the output here.
CLAUDE_CODE_OAUTH_TOKEN=

# Option B — Anthropic API key
# ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Optional overrides (defaults shown) ───────────────────────────────────────
# SKILL_IMAGE=ghcr.io/darthapple/kha:latest
# POLL_INTERVAL=60       # seconds between ClickUp polls
# SLOT_TTL=1800          # seconds before a slot lock auto-expires (crash recovery)
